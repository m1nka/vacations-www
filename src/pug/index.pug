doctype html
html(lang='de')

    head

        meta(charset='utf-8')
        meta(name='viewport', content='width=device-width, initial-scale=1, shrink-to-fit=no')
        meta(name='description', content='Mehr Urlaub – der smarte Urlaubsplaner für iOS und Android. Nutze Feiertage und Brückentage optimal aus und maximiere deine freie Zeit.')
        meta(name='author', content='Maximilian')
        meta(property='og:title', content='Mehr Urlaub – Clever planen, mehr reisen')
        meta(property='og:description', content='Maximiere deine Urlaubszeit mit dem smarten Urlaubsplaner für iOS und Android.')
        meta(property='og:type', content='website')

        title Mehr Urlaub | Urlaubsplaner – App für iOS und Android

        link(rel='icon', type='image/x-icon', href='assets/favicon.ico')

        // Bootstrap icons
        link(href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.5.0/font/bootstrap-icons.css', rel='stylesheet')

        // Google fonts
        link(rel='preconnect', href='https://fonts.googleapis.com')
        link(rel='preconnect', href='https://fonts.gstatic.com', crossorigin)
        link(href='https://fonts.googleapis.com/css2?family=Mulish:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,500&family=Kanit:ital,wght@0,400;0,600;1,400&display=swap', rel='stylesheet')

        // Core theme CSS (includes Bootstrap)
        link(href='css/styles.css', rel='stylesheet')

    body#page-top

        // Navigation
        nav#mainNav.navbar.navbar-expand-lg.fixed-top
            .container.px-5
                .d-flex.align-items-center
                    img(src='assets/img/logo.svg', style='height: 36px; width: 36px;', alt='Mehr Urlaub Logo')
                    a.navbar-brand.ms-2(href='#page-top') Mehr Urlaub
                button.navbar-toggler(type='button', data-bs-toggle='collapse', data-bs-target='#navbarResponsive', aria-controls='navbarResponsive', aria-expanded='false', aria-label='Toggle navigation')
                    | Menu
                    i.bi-list.ms-1
                #navbarResponsive.collapse.navbar-collapse
                    ul.navbar-nav.ms-auto.me-4.my-3.my-lg-0
                        li.nav-item
                            a.nav-link.me-lg-2(href='#screenshots') Screenshots
                        li.nav-item
                            a.nav-link.me-lg-2(href='#features') Features
                    button.btn.btn-primary.rounded-pill.px-3.mb-2.mb-lg-0(data-bs-toggle='modal', data-bs-target='#feedbackModal')
                        span.d-flex.align-items-center
                            i.bi-chat-text-fill.me-2
                            span.small Feedback

        // Hero / Masthead
        header.masthead
            .container.px-5
                .row.gx-5.align-items-center
                    .col-lg-6.order-lg-1
                        // Hero text
                        .masthead-text.mb-5.mb-lg-0.text-center.text-lg-start
                            .hero-overline ✨ Kostenlos &amp; werbefrei
                            h1.font-alt
                                | Clever planen,
                                br
                                | mehr reisen
                            p.lead Nutze Feiertage und Wochenenden perfekt aus – maximiere deine Urlaubszeit mit einem Klick.
                            .d-flex.flex-column.flex-lg-row.align-items-center.align-items-lg-start.gap-3
                                a(href='#!')
                                    img.app-badge(src='assets/img/google-play-badge.svg', alt='Jetzt bei Google Play')
                                a(href='#!')
                                    img.app-badge(src='assets/img/app-store-badge.svg', alt='Laden im App Store')
                    .col-lg-6.order-lg-2
                        // Device mockup
                        .masthead-device-mockup
                            include includes/gradient-circle
                            include includes/shape-1
                            include includes/shape-2
                            .device-wrapper
                                .device(data-device='iPhoneX', data-orientation='portrait', data-color='black')
                                    .screen.bg-white
                                        video(muted='muted', autoplay='', loop='', playsinline='', style='max-width: 100%; height: 100%;')
                                            source(src='assets/img/preview.mp4', type='video/mp4')

        // Support / Buy Me a Coffee section
        aside.support-section
            .container.px-5
                .row.justify-content-center
                    .col-xl-7
                        p.support-headline Kostenfrei und ohne Werbung.
                        p.support-sub Magst du die App unterstützen? Gib mir einen Kaffee aus :-)
                        script(type="text/javascript" src="https://cdnjs.buymeacoffee.com/1.0.0/button.prod.min.js" data-name="bmc-button" data-slug="maximilian.tech" data-color="#f2f2f2" data-emoji="☕" data-font="Bree" data-text="Kaffee ausgeben   " data-outline-color="#000000" data-font-color="#000000" data-coffee-color="#FFDD00")

        // Screenshots section
        section#screenshots
            .container.px-5
                .screenshots-intro
                    span.section-label Screenshots
                    h2.section-heading Die App im Überblick
                    .section-divider
                .screenshots-wrapper
                    .screenshots-slider
                        each val, index in [0, 1, 2, 3, 4]
                            .screenshot-item
                                img(src=`assets/img/Hotpot ${index}.webp`, alt=`App Screenshot ${index + 1}`, draggable='false')
                .p.screenshots-attribution Created with #[a(href='https://hotpot.ai', target='_blank', rel='noopener') hotpot.ai] ♥

        // Features section
        section#features
            .container.px-5
                .row.gx-5.align-items-center
                    // Feature grid
                    .col-lg-8.order-lg-1.mb-5.mb-lg-0
                        .section-intro.mb-5
                            span.section-label Features
                            h2.section-heading Alles, was du brauchst
                        .row.g-4
                            .col-md-6
                                .feature-card
                                    .feature-icon-wrap
                                        i.bi-calendar-check
                                    h3 Ideale Urlaubszeiten
                                    p Mit Feiertagen und Brückentagen deine Urlaubszeit maximieren
                            .col-md-6
                                .feature-card
                                    .feature-icon-wrap
                                        i.bi-calendar2-week
                                    h3 Urlaubskonto verwalten
                                    p Plane und verwalte dein Urlaubskonto mit dem integrierten Kalender
                            .col-md-6
                                .feature-card
                                    .feature-icon-wrap
                                        i.bi-hourglass-split
                                    h3 Urlaubs-Countdown
                                    p Du kannst es nicht erwarten? Zähle runter bis zum nächsten Urlaub
                            .col-md-6
                                .feature-card
                                    .feature-icon-wrap
                                        i.bi-phone
                                    h3 Dark Mode
                                    p Damit die Urlaubsplanung kein Stress für deine Augen wird
                    // Features device mockup
                    .col-lg-4.order-lg-0
                        .features-device-mockup
                            include includes/gradient-circle
                            include includes/shape-1
                            include includes/shape-2
                            .device-wrapper
                                .device(data-device='iPhoneX', data-orientation='portrait', data-color='black')
                                    .screen.bg-white
                                        video(muted='muted', autoplay='', loop='', playsinline='', style='max-width: 100%; height: 100%;')
                                            source(src='assets/img/preview.mp4', type='video/mp4')

        // Download CTA section
        section#download
            .container.px-5
                .row.justify-content-center
                    .col-lg-8.text-center
                        span.section-label Jetzt kostenlos
                        h2.download-headline Starte deinen Traumurlaub
                        p.download-sub Optimiere deine freien Tage – kostenlos, ohne Werbung, für iOS und Android.
                        .d-flex.flex-column.flex-sm-row.align-items-center.justify-content-center.gap-3
                            a(href='#!')
                                img.app-badge(src='assets/img/google-play-badge.svg', alt='Jetzt bei Google Play')
                            a(href='#!')
                                img.app-badge(src='assets/img/app-store-badge.svg', alt='Laden im App Store')

        // Footer
        footer
            .container.px-5
                .d-flex.flex-column.flex-sm-row.align-items-center.justify-content-between.gap-3
                    .d-flex.align-items-center.gap-2
                        img(src='assets/img/logo.svg', style='height: 28px; width: 28px; opacity: 0.7;', alt='Logo')
                        span.footer-logo-brand Mehr Urlaub
                    .footer-legal
                        span &copy; Mehr Urlaub
                        span.separator ·
                        a(data-bs-toggle='modal', data-bs-target='#imprintModal', href='#!') Impressum &amp; Datenschutz

        include includes/feedback-modal.pug
        include includes/imprint-modal.pug

        // Bootstrap core JS
        script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js')

        // Core theme JS
        script(src='js/scripts.js')
